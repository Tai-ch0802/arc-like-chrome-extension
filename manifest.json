{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "version": "1.14.3",
  "homepage_url": "https://sidebar-for-tabs-bookmarks.taislife.work/",
  "permissions": [
    "tabs",
    "sidePanel",
    "bookmarks",
    "tabGroups",
    "storage",
    "readingList",
    "alarms",
    "offscreen",
    "scripting",
    "identity"
  ],
  "oauth2": {
    "client_id": "849720332841-ouhe2qbugvd0skkf5sbjlm3ftnn9loop.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/drive.appdata"]
  },
  "host_permissions": [
    "*://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none';"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "__MSG_extensionName__"
  },
  "icons": {
    "16": "icons/extension-icon-16.png",
    "32": "icons/extension-icon-32.png",
    "48": "icons/extension-icon-48.png",
    "128": "icons/extension-icon-128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+I",
        "mac": "Command+I"
      },
      "description": "__MSG_commandOpenSidePanel__"
    },
    "create-new-tab-right": {
      "suggested_key": {
        "default": "Alt+T",
        "mac": "Alt+T"
      },
      "description": "__MSG_commandCreateNewTabRight__"
    },
    "open-search": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "__MSG_commandOpenSearch__"
    }
  }
}
